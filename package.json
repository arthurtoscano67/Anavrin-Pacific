{
  "name": "autonomous-love-bot-clone",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 5174",
    "build": "vite build",
    "preview": "vite preview --port 5174",
    "renderer:dev": "tsx src/server/martian-renderer.ts",
    "renderer:start": "NODE_ENV=production tsx src/server/martian-renderer.ts",
    "lobby:deploy": "npx wrangler deploy",
    "lobby:dev": "npx wrangler dev --local --port 8787",
    "lobby:tail": "npx wrangler tail",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "arb:dev": "tsx src/solana-arb/index.ts",
    "arb:once": "ARB_RUN_ONCE=true tsx src/solana-arb/index.ts",
    "arb:check": "tsc -p tsconfig.arb.json"
  },
  "dependencies": {
    "@cetusprotocol/aggregator-sdk": "^1.4.5",
    "@cetusprotocol/cetus-sui-clmm-sdk": "^5.4.0",
    "@mysten/dapp-kit": "^0.20.0",
    "@mysten/kiosk": "^0.14.6",
    "@mysten/sui": "^1.45.2",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.17.14",
    "@solana/web3.js": "^1.98.4",
    "@tanstack/react-query": "^5.90.21",
    "@types/express": "^5.0.6",
    "bn.js": "^5.2.3",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "sonner": "^2.0.7",
    "three": "^0.161.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "autoprefixer": "^10.4.27",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.6",
    "typescript": "5.8.2",
    "vite": "^5.4.19"
  }
